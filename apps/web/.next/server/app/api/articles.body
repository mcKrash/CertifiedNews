[{"id":101,"title":"Manchester United secures Champions League spot with dramatic late-season victory","body":"Manchester United clinched their spot in next season's Champions League with a thrilling 3-2 victory over Liverpool, securing their position in the top four with just two matches remaining.","categoryId":1,"sourceUrl":"https://www.bbc.com/sport","sourceName":"BBC Sport","authorId":1,"status":"verified","publishedAt":"2026-04-16T18:30:00.000Z","imageUrl":null,"viewCount":2847},{"id":102,"title":"Tennis star Djokovic announces retirement after legendary 25-year career","body":"In an emotional press conference, Novak Djokovic announced his retirement from professional tennis, ending one of the most dominant careers in the sport's history with 24 Grand Slam titles.","categoryId":1,"sourceUrl":"https://www.espn.com","sourceName":"ESPN Sports","authorId":1,"status":"verified","publishedAt":"2026-04-16T14:15:00.000Z","imageUrl":null,"viewCount":5234},{"id":103,"title":"Olympic Games 2028 Los Angeles: First batch of tickets sells out in record time","body":"The Los Angeles Olympic Committee reported that the first batch of tickets for the 2028 Summer Olympics sold out within 48 hours, breaking previous records for ticket sales.","categoryId":1,"sourceUrl":"https://www.reuters.com","sourceName":"Reuters Sports","authorId":1,"status":"verified","publishedAt":"2026-04-15T10:00:00.000Z","imageUrl":null,"viewCount":1923},{"id":104,"title":"Women's World Cup qualifiers: Historic first-time qualification for emerging nations","body":"Three nations qualified for the Women's World Cup for the first time in history, marking a significant shift in global women's football development.","categoryId":1,"sourceUrl":"https://www.fifa.com","sourceName":"FIFA Official","authorId":1,"status":"verified","publishedAt":"2026-04-14T16:45:00.000Z","imageUrl":null,"viewCount":1456},{"id":105,"title":"International summit reaches landmark climate agreement with binding commitments","body":"World leaders from 195 nations reached a historic agreement on climate action, with binding commitments to reduce carbon emissions by 50% by 2035.","categoryId":2,"sourceUrl":"https://apnews.com","sourceName":"Associated Press","authorId":1,"status":"verified","publishedAt":"2026-04-16T12:00:00.000Z","imageUrl":null,"viewCount":3421},{"id":106,"title":"Parliamentary reform bill passes with overwhelming support from opposition parties","body":"A landmark parliamentary reform bill received unprecedented cross-party support, with 340 votes in favor and only 28 against, signaling a new era of political cooperation.","categoryId":2,"sourceUrl":"https://www.parliament.uk","sourceName":"UK Parliament","authorId":1,"status":"verified","publishedAt":"2026-04-16T09:30:00.000Z","imageUrl":null,"viewCount":2156},{"id":107,"title":"Trade agreement between major economies opens new market opportunities","body":"Representatives from 12 major economies signed a comprehensive trade agreement that is expected to boost cross-border commerce and create thousands of new jobs.","categoryId":2,"sourceUrl":"https://www.wto.org","sourceName":"World Trade Organization","authorId":1,"status":"verified","publishedAt":"2026-04-15T14:20:00.000Z","imageUrl":null,"viewCount":1834},{"id":108,"title":"Election commission announces new voting security measures for upcoming national elections","body":"The national election commission unveiled enhanced security protocols including biometric verification and blockchain-based vote tracking for the upcoming elections.","categoryId":2,"sourceUrl":"https://www.elections.gov","sourceName":"Election Commission","authorId":1,"status":"verified","publishedAt":"2026-04-14T11:00:00.000Z","imageUrl":null,"viewCount":2789},{"id":109,"title":"Breakthrough in quantum computing: New processor achieves 1000-qubit milestone","body":"Tech researchers announced a quantum processor with 1000 qubits, a major breakthrough that could revolutionize computing and drug discovery within the next decade.","categoryId":3,"sourceUrl":"https://www.ibm.com","sourceName":"IBM Research","authorId":1,"status":"verified","publishedAt":"2026-04-16T16:00:00.000Z","imageUrl":null,"viewCount":4567},{"id":110,"title":"AI safety standards adopted by major tech companies in landmark agreement","body":"Leading technology companies agreed to implement unified AI safety standards and establish an independent oversight board to monitor AI development.","categoryId":3,"sourceUrl":"https://www.techcrunch.com","sourceName":"TechCrunch","authorId":1,"status":"verified","publishedAt":"2026-04-16T13:45:00.000Z","imageUrl":null,"viewCount":3892},{"id":111,"title":"New smartphone technology eliminates need for charging cables entirely","body":"A major electronics manufacturer unveiled a revolutionary wireless power transfer technology that eliminates the need for charging cables and batteries.","categoryId":3,"sourceUrl":"https://www.gsmarena.com","sourceName":"GSM Arena","authorId":1,"status":"verified","publishedAt":"2026-04-15T11:30:00.000Z","imageUrl":null,"viewCount":2645},{"id":112,"title":"Cybersecurity researchers discover major vulnerability affecting millions of devices worldwide","body":"Security researchers identified a critical zero-day vulnerability affecting 500 million devices globally and released patches in coordination with manufacturers.","categoryId":3,"sourceUrl":"https://www.cisa.gov","sourceName":"CISA","authorId":1,"status":"verified","publishedAt":"2026-04-14T09:15:00.000Z","imageUrl":null,"viewCount":3421},{"id":113,"title":"Cross-border climate monitoring network expands verified wildfire alerts across three regions","body":"A coordinated public alert network now links emergency agencies, satellite feeds, and accredited newsrooms to reduce misinformation during wildfire events.","categoryId":4,"sourceUrl":"https://www.reuters.com","sourceName":"Reuters Climate Desk","authorId":1,"status":"verified","publishedAt":"2026-04-16T08:30:00.000Z","imageUrl":null,"viewCount":1624},{"id":114,"title":"New study reveals unexpected biodiversity in urban micro-habitats","body":"Researchers found that even small rooftop gardens can support a wide variety of insect species, highlighting the importance of urban greening.","categoryId":4,"sourceUrl":"https://www.nature.com","sourceName":"Nature Environment","authorId":1,"status":"verified","publishedAt":"2026-04-15T10:00:00.000Z","imageUrl":null,"viewCount":512},{"id":115,"title":"Mars rover discovers evidence of ancient microbial life in subsurface samples","body":"NASA's latest Mars rover analysis suggests the presence of fossilized microbial structures in subsurface samples, potentially confirming the existence of ancient life on Mars.","categoryId":4,"sourceUrl":"https://www.nasa.gov","sourceName":"NASA","authorId":1,"status":"verified","publishedAt":"2026-04-16T15:20:00.000Z","imageUrl":null,"viewCount":5821},{"id":116,"title":"Breakthrough in fusion energy: Experimental reactor achieves net-positive energy output","body":"Scientists at a major research facility successfully demonstrated net-positive energy output from a fusion reactor, marking a historic milestone in clean energy research.","categoryId":4,"sourceUrl":"https://www.iter.org","sourceName":"ITER Project","authorId":1,"status":"verified","publishedAt":"2026-04-14T13:00:00.000Z","imageUrl":null,"viewCount":4156},{"id":117,"title":"New vaccine shows 95% effectiveness against emerging respiratory virus variant","body":"Clinical trials of a new vaccine demonstrate 95% effectiveness against the latest variant of a respiratory virus, with minimal side effects reported.","categoryId":5,"sourceUrl":"https://www.who.int","sourceName":"World Health Organization","authorId":1,"status":"verified","publishedAt":"2026-04-16T10:45:00.000Z","imageUrl":null,"viewCount":3267},{"id":118,"title":"Mental health initiative launches free counseling services in underserved communities","body":"A global mental health organization launched a free counseling and support service targeting underserved communities, aiming to reach 5 million people by 2027.","categoryId":5,"sourceUrl":"https://www.mindhealth.org","sourceName":"Mind Health Foundation","authorId":1,"status":"verified","publishedAt":"2026-04-15T14:30:00.000Z","imageUrl":null,"viewCount":1945},{"id":119,"title":"Revolutionary cancer treatment shows promising results in Phase 3 trials","body":"A new immunotherapy treatment for advanced cancer demonstrated a 70% remission rate in Phase 3 clinical trials, potentially offering hope to thousands of patients.","categoryId":5,"sourceUrl":"https://www.cancer.gov","sourceName":"National Cancer Institute","authorId":1,"status":"verified","publishedAt":"2026-04-14T16:15:00.000Z","imageUrl":null,"viewCount":2834},{"id":120,"title":"Global health leaders commit to eliminating preventable diseases by 2030","body":"At an international health summit, leaders from 150 nations committed to eliminating 12 preventable diseases through coordinated vaccination and education campaigns.","categoryId":5,"sourceUrl":"https://www.globalhealth.org","sourceName":"Global Health Alliance","authorId":1,"status":"verified","publishedAt":"2026-04-13T12:00:00.000Z","imageUrl":null,"viewCount":2156}]