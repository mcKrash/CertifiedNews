{
  "name": "certified-news",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "npm --workspace=apps/api run dev",
    "dev:web": "npm --workspace=apps/web run dev",
    "build": "turbo run build",
    "start": "npm --workspace=apps/api start",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "apps/*"
  ]
}
